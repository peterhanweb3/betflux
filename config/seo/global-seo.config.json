	"robotsRules": {
		"production": {
			"allow": ["/"],
			"disallow": ["/api/", "/admin/", "/_next/", "/private/"],
			"sitemap": "https://betflux.games/sitemap.xml"
		},
		"staging": {
			"allow": [],
			"disallow": ["/"],
			"sitemap": null
		}
	},

	"aeo": {
		"enabled": true,
		"generateFAQs": true,
		"generateHowTo": true,
