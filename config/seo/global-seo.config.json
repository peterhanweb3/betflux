				"https://facebook.com/betflux",
				"https://instagram.com/betflux"
			],
			"contactPoint": {
				"@type": "ContactPoint",
				"contactType": "customer support",
				"email": "support@betflux.games"
			}
		},
		"website": {
			"@type": "WebSite",
			"name": "Betflux",
			"url": "https://betflux.games",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://betflux.games/search?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		}
	},

